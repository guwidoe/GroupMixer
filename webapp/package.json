{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build-wasm",
    "dev": "vite",
    "sync:seo-assets": "tsx scripts/seoArtifacts.tsx sync-public",
    "prerender:seo": "tsx scripts/seoArtifacts.tsx prerender-dist",
    "build": "npm run sync:seo-assets && npm run build-wasm && tsc && vite build && npm run prerender:seo",
    "vercel-build": "chmod +x ./vercel-build.sh && ./vercel-build.sh",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview",
    "build-wasm": "wasm-pack build ../backend/wasm --target web --out-dir $(pwd)/public/pkg",
    "test:unit": "vitest --project app",
    "test:unit:watch": "vitest --project app --watch",
    "test:coverage": "vitest --project app --coverage",
    "test:coverage:ci": "vitest --project app --coverage --run",
    "test:runtime-safety:unit": "vitest --project app src/services/browserAgentApi.test.ts src/services/browserAgentBootstrap.test.ts src/services/solverWorker/protocol.test.ts src/services/solverWorker/conversions.test.ts src/services/solverWorker.test.ts src/services/solver/solveProblem.test.ts src/workers/solverWorker.test.ts src/services/wasm/module.test.ts src/services/wasm/contracts.test.ts src/services/wasm.test.ts src/MainApp.integration.test.tsx src/components/ResultsView.test.tsx src/components/ResultsHistory.test.tsx src/components/ManualEditor/hooks/useManualEditorEvaluation.test.ts src/components/ManualEditor/dropPipeline.test.ts src/components/SolverPanel/DetailedMetrics.test.tsx src/components/SolverPanel/utils/runSolverHelpers.test.ts src/components/SolverPanel/utils/saveBestSoFar.test.ts",
    "test:runtime-safety:e2e": "playwright test e2e/tests/workflows.spec.ts --project=chromium",
    "test:runtime-safety": "npm run test:runtime-safety:unit && npm run test:runtime-safety:e2e",
    "test:storybook": "vitest --project storybook",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium --ignore-snapshots --grep-invert \"Visual Regression|Workflow coverage\"",
    "test:e2e:workflows": "playwright test --ignore-snapshots --grep-invert \"Visual Regression\"",
    "test:e2e:perf": "RUN_GRID_PERF=1 playwright test e2e/tests/grid-performance.spec.ts --project=chromium --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:visual": "playwright test visual-regression.spec.ts",
    "test:e2e:visual:stable": "playwright test visual-regression.spec.ts --project=chromium",
    "test:e2e:visual:update": "playwright test visual-regression.spec.ts --update-snapshots",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@react-sigma/core": "^5.0.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.13.2",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.3",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.5",
    "vitest": "^4.1.4"
  }
}
