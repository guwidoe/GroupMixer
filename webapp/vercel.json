{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/test_cases/(.*)",
      "dest": "/test_cases/$1"
    },
    {
      "src": "/app(?:/(.*))?",
      "dest": "/app/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
} 
