# Remote benchmark configuration for GroupMixer
#
# Goal:
# - run the benchmark workflow on a quieter remote machine
# - keep remote benchmark history on one explicit machine lane
# - stage immutable repo snapshots per remote run
# - mirror remote benchmark state locally under:
#     backend/benchmarking/artifacts/remotes/<machine-name>/
#
# Intended workflow:
#   cp ./tools/remote_benchmark.env.example ./tools/remote_benchmark.env
#   # fill this file in
#   ./tools/remote_benchmark_async.sh check
#   ./tools/remote_benchmark_async.sh snapshot
#   ./tools/remote_benchmark_async.sh wait "$(./tools/remote_benchmark_async.sh latest)"
#
# Important:
# - This is for COMPARISONS ON THE SAME REMOTE MACHINE over time.
# - Do not compare absolute timings from the remote machine against your workstation.
# - The script stages this repo into a remote snapshot workspace.
# - The remote machine needs Python 3, cargo, rustc, ssh access, and rsync.

# REQUIRED SETTINGS -----------------------------------------------------------

# SSH target reachable from THIS machine using normal ssh/rsync.
# Example: GROUPMIXER_REMOTE_SSH_TARGET=pi@raspi-bench
GROUPMIXER_REMOTE_SSH_TARGET=

# Short stable label for this remote benchmark machine.
# Example: GROUPMIXER_REMOTE_MACHINE_NAME=raspi4
GROUPMIXER_REMOTE_MACHINE_NAME=

# Absolute remote staging directory.
# Example: GROUPMIXER_REMOTE_STAGE_DIR=/home/pi/bench/GroupMixer-stage
GROUPMIXER_REMOTE_STAGE_DIR=

# OPTIONAL SETTINGS -----------------------------------------------------------

# Optional remote shell env file to source before cargo/rustc commands.
# Example: GROUPMIXER_REMOTE_ENV_FILE=/home/pi/.cargo/env
# GROUPMIXER_REMOTE_ENV_FILE=

# Optional local override if you keep the filled env file somewhere else.
# GROUPMIXER_REMOTE_ENV_FILE_LOCAL=

# Optional SSH / rsync binary overrides.
# GROUPMIXER_REMOTE_SSH_BIN=ssh
# GROUPMIXER_REMOTE_RSYNC_BIN=rsync
# GROUPMIXER_REMOTE_RSYNC_SSH=ssh

# Optional safe remote Python interpreter override used for both the remote
# control helper and the staged benchmark workflow wrapper.
# GROUPMIXER_REMOTE_PYTHON_BIN=/usr/bin/python3

# Codified snapshot suite used by:
#   ./tools/remote_benchmark_async.sh snapshot
# GROUPMIXER_REMOTE_SNAPSHOT_SUITE=representative

# Canonical multi-suite bundles used by:
#   ./tools/remote_benchmark_async.sh record-main
#   ./tools/remote_benchmark_async.sh record-feature <feature-name>
# Values are whitespace-separated suite ids.
# If GROUPMIXER_REMOTE_RECORD_FEATURE_SUITES is unset, it falls back to
# GROUPMIXER_REMOTE_RECORD_MAIN_SUITES.
# GROUPMIXER_REMOTE_RECORD_MAIN_SUITES="representative stretch adversarial hotpath-construction hotpath-full-recalculation hotpath-swap-preview hotpath-swap-apply hotpath-transfer-preview hotpath-transfer-apply hotpath-clique-swap-preview hotpath-clique-swap-apply hotpath-search-iteration"
# GROUPMIXER_REMOTE_RECORD_FEATURE_SUITES="representative stretch adversarial hotpath-construction hotpath-full-recalculation hotpath-swap-preview hotpath-swap-apply hotpath-transfer-preview hotpath-transfer-apply hotpath-clique-swap-preview hotpath-clique-swap-apply hotpath-search-iteration"

# Optional idle gate: once the remote job acquires the exclusive benchmark lock,
# wait until the remote 1-minute load stays at or below the configured threshold.
# GROUPMIXER_REMOTE_BENCH_IDLE_MAX_LOAD1=1.5
# GROUPMIXER_REMOTE_BENCH_IDLE_POLL_SECONDS=30
# GROUPMIXER_REMOTE_BENCH_IDLE_STREAK=2

# Optional watchdog to prevent one pathological run from wedging the queue.
# GROUPMIXER_REMOTE_BENCH_MAX_SECONDS=7200
# GROUPMIXER_REMOTE_BENCH_KILL_AFTER_SECONDS=30

# Optional bound on Cargo release-build parallelism for remote snapshot builds.
# GROUPMIXER_REMOTE_BENCH_BUILD_JOBS=1

# Optional local status-cache TTL in seconds.
# GROUPMIXER_REMOTE_STATUS_LOCAL_TTL_SECONDS=2
