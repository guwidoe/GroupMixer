{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ValidateResponse",
  "description": "Canonical transport-neutral validation response shape.",
  "type": "object",
  "properties": {
    "issues": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ValidationIssue"
      }
    },
    "valid": {
      "type": "boolean"
    }
  },
  "required": [
    "valid"
  ],
  "$defs": {
    "ValidationIssue": {
      "description": "A lightweight validation issue shape suitable for transport-neutral reporting.",
      "type": "object",
      "properties": {
        "code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "message"
      ]
    }
  }
}
