{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PublicErrorEnvelope",
  "description": "Envelope for public transport-level error responses.",
  "type": "object",
  "properties": {
    "error": {
      "$ref": "#/$defs/PublicError"
    }
  },
  "required": [
    "error"
  ],
  "$defs": {
    "PublicError": {
      "description": "Canonical public error instance shape shared across CLI, HTTP, and WASM projections.",
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "recovery": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "related_help": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "valid_alternatives": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "where_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "why": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "code",
        "message"
      ]
    }
  }
}
