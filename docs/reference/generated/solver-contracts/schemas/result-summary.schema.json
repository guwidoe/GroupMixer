{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResultSummary",
  "description": "Lightweight inspect/result metadata for discovery surfaces that need a stable summary without the full schedule payload.",
  "type": "object",
  "required": [
    "attribute_balance_penalty",
    "constraint_penalty",
    "final_score",
    "repetition_penalty",
    "unique_contacts"
  ],
  "properties": {
    "attribute_balance_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "constraint_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "effective_seed": {
      "default": null,
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0.0
    },
    "final_score": {
      "type": "number",
      "format": "double"
    },
    "repetition_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "stop_reason": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "unique_contacts": {
      "type": "integer",
      "format": "int32"
    }
  }
}
