{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResultSummary",
  "description": "Lightweight inspect/result metadata for discovery surfaces that need a stable\nsummary without the full schedule payload.",
  "type": "object",
  "properties": {
    "attribute_balance_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "constraint_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "effective_seed": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "default": null,
      "minimum": 0
    },
    "final_score": {
      "type": "number",
      "format": "double"
    },
    "repetition_penalty": {
      "type": "integer",
      "format": "int32"
    },
    "stop_reason": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "unique_contacts": {
      "type": "integer",
      "format": "int32"
    }
  },
  "required": [
    "final_score",
    "unique_contacts",
    "repetition_penalty",
    "attribute_balance_penalty",
    "constraint_penalty"
  ]
}
