{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://groupmixer.local/benchmarking/schemas/case-run.schema.json",
  "title": "GroupMixer benchmark case run artifact",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "suite_id",
    "benchmark_mode",
    "suite_class",
    "case_id",
    "case_class",
    "case_manifest_path",
    "case_identity",
    "git",
    "machine",
    "solver",
    "effective_budget",
    "artifact_kind",
    "status",
    "timing",
    "runtime_seconds",
    "moves"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "suite_id": { "type": "string" },
    "benchmark_mode": {
      "type": "string",
      "enum": [
        "full_solve",
        "construction",
        "full_recalculation",
        "swap_preview",
        "swap_apply",
        "transfer_preview",
        "transfer_apply",
        "clique_swap_preview",
        "clique_swap_apply",
        "search_iteration"
      ]
    },
    "suite_class": { "$ref": "#/definitions/suiteClass" },
    "case_id": { "type": "string" },
    "case_class": { "$ref": "#/definitions/suiteClass" },
    "case_manifest_path": { "type": "string" },
    "case_identity": { "$ref": "#/definitions/caseIdentity" },
    "case_title": { "type": ["string", "null"] },
    "case_description": { "type": ["string", "null"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "git": { "$ref": "#/definitions/gitIdentity" },
    "machine": { "$ref": "#/definitions/machineIdentity" },
    "solver": { "$ref": "#/definitions/solverMetadata" },
    "effective_seed": { "type": ["integer", "null"] },
    "effective_budget": { "$ref": "#/definitions/effectiveBudget" },
    "artifact_kind": { "type": "string", "enum": ["full_solve", "hot_path"] },
    "effective_move_policy": {
      "type": ["object", "null"],
      "description": "Serialized gm-core MovePolicy"
    },
    "stop_reason": {
      "type": ["string", "null"],
      "enum": [null, "max_iterations_reached", "time_limit_reached", "no_improvement_limit_reached", "progress_callback_requested_stop"]
    },
    "status": {
      "type": "string",
      "enum": ["success", "solver_error"]
    },
    "error_message": { "type": ["string", "null"] },
    "timing": { "$ref": "#/definitions/solveTiming" },
    "runtime_seconds": { "type": "number" },
    "initial_score": { "type": ["number", "null"] },
    "final_score": { "type": ["number", "null"] },
    "best_score": { "type": ["number", "null"] },
    "iteration_count": { "type": ["integer", "null"] },
    "no_improvement_count": { "type": ["integer", "null"] },
    "unique_contacts": { "type": ["integer", "null"] },
    "weighted_repetition_penalty": { "type": ["number", "null"] },
    "weighted_constraint_penalty": { "type": ["number", "null"] },
    "score_decomposition": {
      "anyOf": [
        { "$ref": "#/definitions/scoreDecomposition" },
        { "type": "null" }
      ]
    },
    "search_telemetry": {
      "type": ["object", "null"],
      "required": [
        "accepted_uphill_moves",
        "accepted_downhill_moves",
        "accepted_neutral_moves",
        "max_no_improvement_streak",
        "restart_count",
        "perturbation_count",
        "iterations_per_second",
        "best_score_timeline",
        "repeat_guided_swaps",
        "memetic"
      ],
      "properties": {
        "accepted_uphill_moves": { "type": "integer" },
        "accepted_downhill_moves": { "type": "integer" },
        "accepted_neutral_moves": { "type": "integer" },
        "max_no_improvement_streak": { "type": "integer" },
        "restart_count": { "type": ["integer", "null"] },
        "perturbation_count": { "type": ["integer", "null"] },
        "iterations_per_second": { "type": "number" },
        "best_score_timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["iteration", "elapsed_seconds", "best_score"],
            "properties": {
              "iteration": { "type": "integer" },
              "elapsed_seconds": { "type": "number" },
              "best_score": { "type": "number" }
            }
          }
        },
        "repeat_guided_swaps": {
          "type": "object",
          "required": [
            "guided_attempts",
            "guided_successes",
            "guided_fallback_to_random",
            "guided_previewed_candidates"
          ],
          "properties": {
            "guided_attempts": { "type": "integer" },
            "guided_successes": { "type": "integer" },
            "guided_fallback_to_random": { "type": "integer" },
            "guided_previewed_candidates": { "type": "integer" }
          }
        },
        "memetic": {
          "type": ["object", "null"],
          "required": [
            "population_size",
            "parent_tournament_size",
            "offspring_generated",
            "mutation_attempted_swaps",
            "mutation_applied_swaps",
            "child_polish_iterations",
            "child_polish_improving_moves",
            "replacements"
          ],
          "properties": {
            "population_size": { "type": "integer" },
            "parent_tournament_size": { "type": "integer" },
            "offspring_generated": { "type": "integer" },
            "mutation_attempted_swaps": { "type": "integer" },
            "mutation_applied_swaps": { "type": "integer" },
            "child_polish_iterations": { "type": "integer" },
            "child_polish_improving_moves": { "type": "integer" },
            "replacements": { "type": "integer" }
          }
        }
      }
    },
    "moves": {
      "type": "object",
      "description": "Serialized gm-core MoveFamilyBenchmarkTelemetrySummary (attempts/accepted/improving_accepts/rejected plus timing counters per move family)."
    },
    "hotpath_metrics": {
      "type": ["object", "null"],
      "required": [
        "benchmark_mode",
        "iterations",
        "warmup_iterations",
        "measured_operations",
        "average_runtime_seconds",
        "ops_per_second",
        "checksum",
        "measurement_seconds",
        "setup_seconds",
        "construction_seconds",
        "preview_seconds",
        "apply_seconds",
        "full_recalculation_seconds",
        "search_seconds"
      ],
      "properties": {
        "benchmark_mode": { "type": "string" },
        "preset": { "type": ["string", "null"] },
        "iterations": { "type": "integer" },
        "warmup_iterations": { "type": "integer" },
        "measured_operations": { "type": "integer" },
        "average_runtime_seconds": { "type": "number" },
        "ops_per_second": { "type": "number" },
        "checksum": { "type": "integer" },
        "measurement_seconds": { "type": "number" },
        "setup_seconds": { "type": "number" },
        "construction_seconds": { "type": "number" },
        "preview_seconds": { "type": "number" },
        "apply_seconds": { "type": "number" },
        "full_recalculation_seconds": { "type": "number" },
        "search_seconds": { "type": "number" }
      }
    },
    "external_validation": {
      "type": ["object", "null"],
      "required": [
        "validation_passed",
        "total_score_agreement",
        "score_breakdown_agreement",
        "invariants_passed",
        "schedule_roundtrip_exact",
        "component_agreement",
        "reported",
        "recomputed",
        "mismatch_diagnostics"
      ],
      "properties": {
        "validation_passed": { "type": "boolean" },
        "total_score_agreement": { "type": "boolean" },
        "score_breakdown_agreement": { "type": "boolean" },
        "invariants_passed": { "type": "boolean" },
        "schedule_roundtrip_exact": { "type": "boolean" },
        "component_agreement": {
          "type": "object",
          "required": [
            "final_score",
            "unique_contacts",
            "repetition_penalty",
            "attribute_balance_penalty",
            "constraint_penalty",
            "weighted_repetition_penalty",
            "weighted_constraint_penalty"
          ],
          "properties": {
            "final_score": { "type": "boolean" },
            "unique_contacts": { "type": "boolean" },
            "repetition_penalty": { "type": "boolean" },
            "attribute_balance_penalty": { "type": "boolean" },
            "constraint_penalty": { "type": "boolean" },
            "weighted_repetition_penalty": { "type": "boolean" },
            "weighted_constraint_penalty": { "type": "boolean" }
          }
        },
        "reported": {
          "type": "object",
          "required": [
            "final_score",
            "unique_contacts",
            "repetition_penalty",
            "attribute_balance_penalty",
            "constraint_penalty",
            "weighted_repetition_penalty",
            "weighted_constraint_penalty"
          ],
          "properties": {
            "final_score": { "type": "number" },
            "unique_contacts": { "type": "integer" },
            "repetition_penalty": { "type": "integer" },
            "attribute_balance_penalty": { "type": "integer" },
            "constraint_penalty": { "type": "integer" },
            "weighted_repetition_penalty": { "type": "number" },
            "weighted_constraint_penalty": { "type": "number" }
          }
        },
        "recomputed": {
          "type": ["object", "null"],
          "required": [
            "total_score",
            "baseline_score",
            "unique_contacts",
            "repetition_penalty",
            "weighted_repetition_penalty",
            "attribute_balance_penalty",
            "constraint_penalty",
            "weighted_constraint_penalty",
            "clique_violations",
            "forbidden_pair_violations",
            "should_together_violations",
            "immovable_violations",
            "pair_meeting_counts"
          ],
          "properties": {
            "total_score": { "type": "number" },
            "baseline_score": { "type": "number" },
            "unique_contacts": { "type": "integer" },
            "repetition_penalty": { "type": "integer" },
            "weighted_repetition_penalty": { "type": "number" },
            "attribute_balance_penalty": { "type": "number" },
            "constraint_penalty": { "type": "integer" },
            "weighted_constraint_penalty": { "type": "number" },
            "clique_violations": { "type": "array", "items": { "type": "integer" } },
            "forbidden_pair_violations": { "type": "array", "items": { "type": "integer" } },
            "should_together_violations": { "type": "array", "items": { "type": "integer" } },
            "immovable_violations": { "type": "integer" },
            "pair_meeting_counts": { "type": "array", "items": { "type": "integer" } }
          }
        },
        "mismatch_diagnostics": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "suiteClass": {
      "type": "string",
      "enum": ["path", "representative", "stretch", "adversarial"]
    },
    "gitIdentity": {
      "type": "object",
      "required": ["commit_sha", "short_sha", "branch", "dirty_tree"],
      "properties": {
        "commit_sha": { "type": ["string", "null"] },
        "short_sha": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "dirty_tree": { "type": ["boolean", "null"] }
      }
    },
    "machineIdentity": {
      "type": "object",
      "required": ["benchmark_machine_id", "hostname", "cpu_model", "logical_cores", "os", "kernel", "rustc_version", "cargo_profile"],
      "properties": {
        "benchmark_machine_id": { "type": ["string", "null"] },
        "hostname": { "type": ["string", "null"] },
        "cpu_model": { "type": ["string", "null"] },
        "logical_cores": { "type": ["integer", "null"] },
        "os": { "type": ["string", "null"] },
        "kernel": { "type": ["string", "null"] },
        "rustc_version": { "type": ["string", "null"] },
        "cargo_profile": { "type": ["string", "null"] }
      }
    },
    "effectiveBudget": {
      "type": "object",
      "required": ["max_iterations", "time_limit_seconds", "no_improvement_iterations"],
      "properties": {
        "max_iterations": { "type": ["integer", "null"] },
        "time_limit_seconds": { "type": ["integer", "null"] },
        "no_improvement_iterations": { "type": ["integer", "null"] }
      }
    },
    "solveTiming": {
      "type": "object",
      "required": ["initialization_seconds", "search_seconds", "finalization_seconds", "total_seconds"],
      "properties": {
        "initialization_seconds": { "type": "number" },
        "search_seconds": { "type": "number" },
        "finalization_seconds": { "type": "number" },
        "total_seconds": { "type": "number" }
      }
    },
    "solverMetadata": {
      "type": "object",
      "required": ["solver_family", "solver_config_id", "display_name", "seed_policy", "capabilities"],
      "properties": {
        "solver_family": { "type": "string" },
        "solver_config_id": { "type": "string" },
        "display_name": { "type": "string" },
        "seed_policy": { "type": "string", "enum": ["explicit", "runtime_generated", "not_applicable"] },
        "capabilities": {
          "type": "object",
          "required": [
            "supports_initial_schedule",
            "supports_progress_callback",
            "supports_benchmark_observer",
            "supports_recommended_settings",
            "supports_deterministic_seed"
          ],
          "properties": {
            "supports_initial_schedule": { "type": "boolean" },
            "supports_progress_callback": { "type": "boolean" },
            "supports_benchmark_observer": { "type": "boolean" },
            "supports_recommended_settings": { "type": "boolean" },
            "supports_deterministic_seed": { "type": "boolean" }
          }
        }
      }
    },
    "caseIdentity": {
      "type": "object",
      "required": [
        "source_path",
        "canonical_case_id",
        "case_role",
        "source_fingerprint",
        "purpose_provenance_summary",
        "declared_budget"
      ],
      "properties": {
        "source_path": { "type": "string" },
        "canonical_case_id": { "type": "string" },
        "case_role": {
          "type": "string",
          "enum": ["canonical", "helper", "derived", "proxy", "warm_start", "benchmark_start"]
        },
        "source_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "purpose_provenance_summary": { "type": ["string", "null"] },
        "declared_budget": {
          "type": ["object", "null"],
          "required": ["max_iterations", "time_limit_seconds"],
          "properties": {
            "max_iterations": { "type": ["integer", "null"] },
            "time_limit_seconds": { "type": ["integer", "null"] }
          }
        }
      }
    },
    "constraintFamilyContribution": {
      "type": "object",
      "required": ["weighted_penalty", "raw_violations"],
      "properties": {
        "weighted_penalty": { "type": "number" },
        "raw_violations": { "type": "integer" }
      }
    },
    "weightedConstraintBreakdown": {
      "type": "object",
      "required": [
        "forbidden_pair",
        "should_stay_together",
        "pair_meeting_count",
        "clique",
        "immovable",
        "residual_weighted_penalty"
      ],
      "properties": {
        "forbidden_pair": { "$ref": "#/definitions/constraintFamilyContribution" },
        "should_stay_together": { "$ref": "#/definitions/constraintFamilyContribution" },
        "pair_meeting_count": { "$ref": "#/definitions/constraintFamilyContribution" },
        "clique": { "$ref": "#/definitions/constraintFamilyContribution" },
        "immovable": { "$ref": "#/definitions/constraintFamilyContribution" },
        "residual_weighted_penalty": { "type": "number" }
      }
    },
    "scoreDecomposition": {
      "type": "object",
      "required": [
        "total_score",
        "baseline_score",
        "unique_contacts",
        "unique_contact_weight",
        "unique_contact_term",
        "repetition_penalty",
        "repetition_term",
        "attribute_balance_term",
        "weighted_constraint_total",
        "weighted_constraint_breakdown"
      ],
      "properties": {
        "total_score": { "type": "number" },
        "baseline_score": { "type": "number" },
        "unique_contacts": { "type": "integer" },
        "unique_contact_weight": { "type": "number" },
        "unique_contact_term": { "type": "number" },
        "repetition_penalty": { "type": "integer" },
        "repetition_term": { "type": "number" },
        "attribute_balance_term": { "type": "number" },
        "weighted_constraint_total": { "type": "number" },
        "weighted_constraint_breakdown": {
          "$ref": "#/definitions/weightedConstraintBreakdown"
        }
      }
    }
  }
}
